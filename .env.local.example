# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Payment gateways (checkout) ─────────────────────────────────────────────
# All optional. With none set, checkout runs in safe DEMO mode (no real charge).
# Set a gateway's keys to switch it to LIVE automatically.

# Stripe → powers Card, Apple Pay, Google Pay & Cash App Pay
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal → Orders API (use PAYPAL_ENV=live for production)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENV=sandbox

# Crypto → Coinbase Commerce (BTC, ETH, USDC…)
COINBASE_COMMERCE_API_KEY=your-coinbase-commerce-key

# Whop → Whop Checkout (plan-based hosted checkout)
WHOP_API_KEY=your-whop-api-key
WHOP_PLAN_ID=plan_xxxxxxxx

# ─── Price APIs ──────────────────────────────────────────────────────────────
# TCGPlayer (EN) – request access at tcgplayer.com/developers
TCGPLAYER_PUBLIC_KEY=your-tcgplayer-public-key
TCGPLAYER_PRIVATE_KEY=your-tcgplayer-private-key

# Scryfall (MTG) – free, no key needed
# YGOProDeck – free, no key needed
# PokémonTCG API – free tier available
POKEMON_TCG_API_KEY=your-pokemon-tcg-key

# ─── Email (Resend – for restock alerts) ─────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCOUNT_RATE=0.30
