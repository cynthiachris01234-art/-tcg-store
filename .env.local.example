# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Price APIs ──────────────────────────────────────────────────────────────
# TCGPlayer (EN) – request access at tcgplayer.com/developers
TCGPLAYER_PUBLIC_KEY=your-tcgplayer-public-key
TCGPLAYER_PRIVATE_KEY=your-tcgplayer-private-key

# Scryfall (MTG) – free, no key needed
# YGOProDeck – free, no key needed
# PokémonTCG API – free tier available
POKEMON_TCG_API_KEY=your-pokemon-tcg-key

# ─── Email (Resend – for restock alerts) ─────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCOUNT_RATE=0.30
